--information:VectorCanvas ${VERSION} by ${AUTHOR}

---$text:パスコマンド
local command = "M -100 -100 L 100 -100 L 100 100 L -100 100 Z"

if _vectorcanvas == nil then
    print("@error", "ベクターキャンバスが作成されていません。「キャンバス@VectorCanvas」を追加してください。")
    return
end

command = tostring(command or "")
command = command:gsub("[\r\n]+", " ")

if command:match("%S") then
    table.insert(_vectorcanvas.canvas, "path: " .. command)
end
